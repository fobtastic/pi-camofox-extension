# Copy this file to .env or .env.local.
# Do not commit real credentials.

# Optional: override the local camofox server URL.
# CAMOFOX_BASE_URL=http://127.0.0.1:9377

# Optional proxy URL for camofox-browser.
CAMOFOX_PROXY_URL=http://proxy-username:proxy-password@proxy-host:port
CAMOFOX_PROXY_BYPASS=localhost,127.0.0.1
